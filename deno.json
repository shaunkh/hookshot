{
  "name": "@ostium/sdk-hackathon",
  "version": "0.1.0",
  "exports": "./src/main.ts",
  "tasks": {
    "dev": "deno run --watch --env-file --allow-net --allow-env src/main.ts",
    "run": "deno run --env-file --allow-net --allow-env src/main.ts",
    "test": "deno test --allow-net --allow-env",
    "check": "deno check src/main.ts",
    "fmt": "deno fmt",
    "lint": "deno lint"
  },
  "imports": {
    "@ostium/builder-sdk": "npm:@ostium/builder-sdk@^0.4.0",
    "viem": "npm:viem@^2",
    "@std/assert": "jsr:@std/assert@^1.0.0"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    },
    "exclude": ["src/main_test.ts"]
  }
}
