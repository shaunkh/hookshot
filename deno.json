{
  "nodeModulesDir": "manual",
  "tasks": {
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "check": "deno fmt --check . && deno lint . && deno check",
    "test": "deno test --allow-read --allow-write --allow-env --allow-net",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": {
    "rules": { "tags": ["fresh", "recommended"] },
    "exclude": ["_fresh", "node_modules"]
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false,
    "exclude": ["_fresh", "node_modules", "deno.lock"]
  },
  "exclude": ["**/_fresh/*", "node_modules"],
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "preact": "npm:preact@^10.29.1",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "vite": "npm:vite@^7.1.3",
    "@types/node": "npm:@types/node@^22.10.0",
    "@ostium/builder-sdk": "npm:@ostium/builder-sdk@^0.4.0",
    "viem": "npm:viem@^2",
    "valibot": "jsr:@valibot/valibot@^1.4.1",
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/http": "jsr:@std/http@^1.0.0",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  }
}
